# Preferred: explicitly provide non-local Supabase credentials
SUPABASE_NON_LOCAL_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_NON_LOCAL_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Backward-compatible fallback (used only if NON_LOCAL vars above are not set)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Target table (default is public.thoughts if omitted)
OPENBRAIN_MEMORIES_TABLE=public.thoughts

# Optional safety override for local testing only
# SUPABASE_ALLOW_LOCAL=1

# Optional for non-local deployments where frontend and API are on different origins
# Example: https://api.example.com
NEXT_PUBLIC_DASHBOARD_API_BASE_URL=
